{
  "name": "gs-slam-visual-console",
  "version": "0.3.8",
  "private": true,
  "description": "A bilingual desktop console for 3DGS-SLAM dataset inspection and runtime orchestration.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder --dir",
    "build:installer": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:renderer": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.5.0",
    "cors": "^2.8.5",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.17.0",
    "three": "^0.184.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gs-slam.visual-console",
    "productName": "SLAM-3DGS控制台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ZhouYi109",
        "repo": "gs-slam-visual-console",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "extraResources": [
      {
        "from": "ros_bridge",
        "to": "ros_bridge"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "SLAM-3DGS控制台",
      "allowElevation": true,
      "include": "installer.nsh"
    }
  }
}
